{
  "name": "appraisal-management-backend",
  "version": "1.0.0",
  "description": "Enterprise Appraisal Management System Backend",
  "main": "dist/server.js",
  "pnpm": {
    "overrides": {
      "@types/express-serve-static-core": "^4.19.8"
    }
  },
  "overrides": {
    "fast-xml-parser": "^5.5.7",
    "flatted": "^3.4.2",
    "js-yaml": "^4.1.1",
    "qs": "^6.15.0",
    "@azure/identity": "^4.13.1",
    "brace-expansion": "^2.0.3"
  },
  "scripts": {
    "build": "npx tsc",
    "build:production": "npx tsc",
    "start": "node dist/app-production.js",
    "start:dev": "node dist/server.js",
    "start:minimal": "node dist/minimal-server.js",
    "dev": "tsx --env-file .env --watch src/app-production.ts",
    "dev:minimal": "tsx --env-file .env --watch src/minimal-server.ts",
    "dev:production": "tsx --env-file .env --watch src/app-production.ts",
    "api": "tsx --env-file .env --watch src/app-production.ts",
    "verify:axiom-contract": "tsx scripts/verify-axiom-contract.ts",
    "axiom:livefire:property-intake": "tsx scripts/live-fire/axiom-live-fire-property-intake.ts",
    "axiom:livefire:document-flow": "tsx scripts/live-fire/axiom-live-fire-document-flow.ts",
    "axiom:livefire:analyze-webhook": "tsx scripts/live-fire/axiom-live-fire-analyze-and-webhook.ts",
    "axiom:livefire:preflight": "tsx scripts/live-fire/axiom-live-fire-preflight-probe.ts",
    "axiom:livefire:remote-suite": "tsx scripts/live-fire/axiom-live-fire-remote-suite.ts",
    "axiom:livefire:verify-local-remote": "tsx scripts/live-fire/axiom-live-fire-verify-local-remote.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --reporter=verbose tests/integration",
    "test:integration:production": "vitest run --reporter=verbose tests/integration/production-api.test.ts",
    "test:comprehensive": "vitest run --reporter=verbose tests/integration/comprehensive-api.test.ts",
    "test:comprehensive:runner": "node scripts/run-comprehensive-tests.js",
    "test:external-services": "vitest run --reporter=verbose tests/integration/external-services.test.ts",
    "test:external-services-fixed": "vitest run --reporter=verbose tests/integration/external-services-fixed.test.ts",
    "test:real-api-validation": "vitest run --reporter=verbose tests/integration/real-api-validation.test.ts",
    "test:minimal-server": "vitest run --reporter=verbose tests/integration/minimal-server.test.ts",
    "test:all-integrations": "vitest run --reporter=verbose tests/integration/",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:cosmos": "ts-node src/tests/cosmos-db-test-runner.ts",
    "test:cosmos-service": "ts-node src/tests/cosmos-service-test.ts",
    "seed": "npx tsx src/scripts/seed/index.ts",
    "seed:module": "npx tsx src/scripts/seed/index.ts --module",
    "seed:clean": "npx tsx src/scripts/seed/index.ts --clean",
    "seed:clean-only": "npx tsx src/scripts/seed/index.ts --clean-only",
    "seed:list": "npx tsx src/scripts/seed/index.ts --list",
    "test:vendor": "node scripts/test-vendor-enhancements.js",
    "health-check": "tsx --env-file .env src/run-health-check.ts",
    "test:authorization": "ts-node scripts/test-authorization.ts",
    "create-test-orders": "ts-node scripts/create-test-orders.ts",
    "deploy:vendor-containers": "az deployment group create --resource-group <rg-name> --template-file infrastructure/vendor-marketplace-containers.bicep --parameters cosmosAccountName=<cosmos-account>",
    "job:vendor-metrics": "ts-node src/jobs/calculate-vendor-metrics.job.ts",
    "test:vendor-performance": "vitest run --reporter=verbose tests/integration/vendor-performance.test.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "npx tsc --noEmit",
    "clean": "rm -rf dist/",
    "build:clean": "npm run clean && npm run build",
    "docker:build": "docker build -t appraisal-backend:latest .",
    "docker:build:prod": "docker build --target production -t appraisal-backend:production .",
    "docker:run": "docker run -p 8080:8080 appraisal-backend:latest",
    "docker:run:dev": "docker-compose up --build",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f appraisal-backend",
    "functions:install": "npm install --prefix src/functions",
    "functions:start": "npm run start --prefix src/functions",
    "functions:test": "npm run test --prefix src/functions",
    "functions:docker:build": "docker build -f src/functions/Dockerfile -t appraisal-functions:latest src/functions",
    "azure:acr:build": "az acr build --registry $ACR_NAME --image appraisal-backend:latest .",
    "azure:acr:tag": "az acr import --name $ACR_NAME --source appraisal-backend:latest --image appraisal-backend:$BUILD_NUMBER",
    "deploy:azure": "npm run build && echo 'Ready for Azure deployment'",
    "deploy:infrastructure": "az deployment sub create --location eastus --template-file infrastructure/main-production-parameterized.bicep --parameters @infrastructure/parameters/production-fully-parameterized.parameters.json",
    "health:check": "curl -f http://localhost:8080/health || curl -f http://localhost:3000/health"
  },
  "keywords": [
    "appraisal",
    "valuation",
    "real-estate",
    "ai",
    "typescript",
    "azure"
  ],
  "author": "Appraisal Management Team",
  "license": "MIT",
  "dependencies": {
    "@azure/communication-calling": "^1.42.1",
    "@azure/communication-chat": "^1.6.0",
    "@azure/app-configuration": "^1.9.0",
    "@azure/communication-common": "^2.4.0",
    "@azure/communication-email": "^1.1.0",
    "@azure/communication-identity": "^1.3.1",
    "@azure/communication-sms": "^1.2.0-beta.4",
    "@azure/core-auth": "^1.10.1",
    "@azure/cosmos": "^4.9.2",
    "@azure/event-hubs": "^5.11.2",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.7.0",
    "@azure/openai": "^1.0.0-beta.12",
    "@azure/service-bus": "^7.9.5",
    "@azure/storage-blob": "^12.31.0",
    "@azure/web-pubsub": "^1.2.0",
    "@azure/web-pubsub-express": "^1.0.6",
    "@fluidframework/azure-service-utils": "^2.90.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@types/pdfkit": "^0.17.5",
    "applicationinsights": "^3.14.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "casbin": "^5.49.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "eventsource": "^4.1.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.2.2",
    "handlebars": "^4.7.9",
    "helmet": "^7.1.0",
    "intuit-oauth": "^4.2.2",
    "ioredis": "^5.3.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mongodb": "^6.21.0",
    "morgan": "^1.10.0",
    "mssql": "^9.1.1",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "openai": "^6.32.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "redis": "^4.6.10",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xmlbuilder2": "^4.0.3",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/eventsource": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "4.19.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.17",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^2.0.16",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "supertest": "^6.3.4",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
