# ─── Appraisal Management Backend — Environment Variables ────────────────────
#
# Copy this file to .env and fill in the values for your environment.
# All Azure SDK clients use Managed Identity (DefaultAzureCredential) in
# production — no keys or connection strings.
#
# Required variables are marked [REQUIRED]. Optional are marked [OPTIONAL].
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development                   # development | production | test [REQUIRED]
PORT=3011                              # HTTP listen port [OPTIONAL — default: 3011]

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Managed Identity is used in production. For local dev with Azurite use the
# emulator endpoint below.
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443    # [REQUIRED]
# AZURE_COSMOS_ENDPOINT=                                      # alias accepted by cosmos-db.service.ts

# ── Azure Managed Identity ────────────────────────────────────────────────────
# Set AZURE_CLIENT_ID if a user-assigned managed identity is needed (optional
# when system-assigned identity is configured).
# AZURE_CLIENT_ID=<object-id-of-user-assigned-managed-identity>

# ── Azure Service Bus ─────────────────────────────────────────────────────────
AZURE_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net   # [REQUIRED]
# USE_MOCK_SERVICE_BUS=true    # set to 'true' in development to skip real SB

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=<storage-account-name>   # [REQUIRED for document upload]
STORAGE_CONTAINER_DOCUMENTS=documents               # [OPTIONAL — default: documents]
BULK_UPLOAD_STORAGE_ACCOUNT_NAME=<bulk-upload-storage-account>  # [REQUIRED for bulk ingestion]

# ── Azure Key Vault ───────────────────────────────────────────────────────────
KEY_VAULT_URL=https://<vault-name>.vault.azure.net   # [REQUIRED for collaboration features]

# ── Property Data Enrichment ──────────────────────────────────────────────────
# At least one provider should be configured for subject property enrichment.
# When BOTH are set the service chains them: Bridge is tried first (MLS data),
# then ATTOM as a public-records fallback when Bridge returns no result.
# When neither is set enrichment is skipped (NullPropertyDataProvider warns).

# Bridge Interactive — provides MLS-linked data (AVM, public records)
# BRIDGE_SERVER_TOKEN=<your-bridge-interactive-server-token>

# ATTOM Data Solutions — 155M+ property public records (APN, assessment, flood)
# Only needed if calling the live ATTOM API. The property-data-cache is checked first;
# a missing key only causes failures on cache misses, not on cache hits.
# ATTOM_API_KEY=<your-attom-api-key>

# ── Property Data Cache (Cosmos: property-data-cache container) ───────────────
# How many days a cached property record is considered fresh before the live API
# is called to refresh it. Set to 0 (default) to never auto-refresh (cache forever).
ATTOM_CACHE_TTL_DAYS=0   # [OPTIONAL — default: 0 (never expire)]

# ── ATTOM CSV Ingestion (src/scripts/ingest-attom-csv.ts) ────────────────────
# Run once (and idempotently) to populate property-data-cache from the ATTOM
# CSV files stored in Azure Blob.
ATTOM_CSV_STORAGE_ACCOUNT=apprdev7iqxpvst         # [REQUIRED for ingestion]
ATTOM_CSV_CONTAINER=attom-data                     # [OPTIONAL — default: attom-data]
ATTOM_CSV_BLOBS=Duval_FL_2025_2026.csv,LA_2025_2026.csv  # [OPTIONAL — default: both FL+LA]
# ATTOM_CSV_BATCH_SIZE=100                         # [OPTIONAL — records per Cosmos batch]
# ATTOM_CSV_DRY_RUN=true                           # [OPTIONAL — parse without writing]

# How many days to consider an enrichment record "fresh" before re-fetching.
# Set to 0 to disable caching (always re-fetch).
ENRICHMENT_CACHE_TTL_DAYS=30   # [OPTIONAL — default: 30]

# ── Bulk Ingestion ────────────────────────────────────────────────────────────
BULK_INGESTION_DOCUMENT_UPLOAD_CONCURRENCY=16   # [OPTIONAL — default: 16]
BULK_INGESTION_ENABLE_CRITERIA_STAGE=true        # [OPTIONAL — set to 'true' to enable per-item criteria evaluation; omit to skip]

# ── Axiom AI Platform ─────────────────────────────────────────────────────────
# Axiom is the AI pipeline backend for document extraction and criteria evaluation.
# See AXIOM_API_REFERENCE.md for full API docs.

AXIOM_API_BASE_URL=https://axiom-dev-api.ambitioushill-a89e4aa0.eastus.azurecontainerapps.io  # [REQUIRED — Axiom API endpoint]

# Axiom clientId and subClientId are NOT runtime env vars — they are per-order values
# read from the order/engagement document in Cosmos (set at order creation time).
# See the Seed Bootstrap section below for the values used to populate seed data.

# Axiom authentication
# AXIOM_AUTH_REQUIRED controls whether the service attaches an auth header:
#   false  = no auth header sent (Axiom dev accepts unauthenticated calls — use this locally)
#   true   = require DefaultAzureCredential / Managed Identity (production)
#   (unset) = legacy heuristic: use DefaultAzureCredential only if explicitly opted in
# In production: AXIOM_AUTH_REQUIRED=true + AXIOM_AUTH_AUDIENCE must both be set.
# In local dev without Azure AD: AXIOM_AUTH_REQUIRED=false (no API key needed for dev endpoint).
AXIOM_AUTH_REQUIRED=false                         # [REQUIRED — set to true in production]
# AXIOM_API_KEY=                                  # [OPTIONAL — static bearer token, mutually exclusive with DefaultAzureCredential]
AXIOM_USE_DEFAULT_CREDENTIAL=true                 # [OPTIONAL — legacy opt-in; prefer AXIOM_AUTH_REQUIRED=true]
AXIOM_AUTH_AUDIENCE=api://<axiom-app-registration-guid>  # [REQUIRED when AXIOM_AUTH_REQUIRED=true — Axiom's Azure AD app registration URI, e.g. api://3bc96929-...]
# AXIOM_API_TOKEN_SCOPE=                          # [OPTIONAL — override full scope string incl. /.default suffix]
# AXIOM_API_RESOURCE=                             # [OPTIONAL — legacy alias for AXIOM_AUTH_AUDIENCE]
# AXIOM_RISK_THRESHOLD=70                         # [OPTIONAL — overallRiskScore >= this publishes axiom.risk.threshold.crossed]

# Axiom circuit breaker tuning (optional — production defaults shown)
# AXIOM_CB_FAILURE_THRESHOLD=5                    # open after N consecutive 5xx responses
# AXIOM_CB_OPEN_MS=60000                          # stay open for this many ms before probe

# ── Seed Bootstrap (seed scripts only — NOT read by the application at runtime) ──
# These values are used by src/scripts/seed/index.ts to stamp clientId and
# subClientId onto every seeded order, client, and engagement document so that
# seeded data round-trips correctly through Axiom pipelines.
#
# clientId   = our platform's registered identity at Axiom  (e.g. 'vision' in prod,
#              'test-client' when running against the shared Axiom dev environment)
# subClientId = the default partition slug for seed data     (e.g. 'platform' in prod,
#              'test-tenant' when using Axiom dev)
#
# Per-order subClientId values (e.g. 'firsthorizon') are set individually in each
# seed document and override this default at eval time.
#
# The application NEVER reads these at runtime — clientId/subClientId always come
# from the order/engagement document in Cosmos.
AXIOM_CLIENT_ID=vision                  # [SEED ONLY — Axiom clientId to stamp on seeded data]
AXIOM_SUB_CLIENT_ID=platform            # [SEED ONLY — default Axiom subClientId for seeded data]

# ── Inspection Vendor (REQUIRED at app startup) ───────────────────────────────
# The inspection-vendor framework (src/services/inspection-providers/) requires
# INSPECTION_PROVIDER to be set; the app fails fast at startup if it is missing.
# Currently the only supported value is 'ivueit'. iVueit also requires API
# credentials below. For local dev without real iVueit access, placeholder
# values are sufficient to start the app (real calls fail at runtime).
INSPECTION_PROVIDER=ivueit
IVUEIT_API_KEY=                         # iVueit API key (placeholder OK for local dev)
IVUEIT_SECRET=                          # iVueit secret (placeholder OK for local dev)
IVUEIT_BASE_URL=https://api.ivueit.com  # iVueit base URL
# IVUEIT_SURVEY_TEMPLATE_ID=            # optional: default survey template ID

# ── MOP Vendor-Matching Rule Pack Provider ──────────────────────────────────
# Phase 3 of docs/AUTO_ASSIGNMENT_REVIEW.md. AMS pushes per-tenant rule packs
# to MOP and surfaces MOP's seed pack in the rules workspace. Without
# MOP_RULES_BASE_URL set, the rules workspace shows "MOP seed unreachable"
# and the seed-from-default endpoint returns 503.
#
# For local dev pointing at MOP dev:
#   MOP_RULES_BASE_URL=https://ca-mop-dev.<cae-id>.eastus2.azurecontainerapps.io
#   MOP_RULES_SERVICE_AUTH_TOKEN=<value of sentinel KV secret sentinel-mop-webhook-secret>
#
# RULES_PROVIDER selects how vendor-matching evaluations actually run:
#   homegrown          — in-process rules engine (default; safe; no MOP dependency)
#   mop                — MOP only; fail-closed if MOP is down
#   mop-with-fallback  — MOP primary, homegrown fallback (recommended once MOP is live)
MOP_RULES_BASE_URL=                     # MOP base URL (required for rules workspace UI)
MOP_RULES_SERVICE_AUTH_TOKEN=           # X-Service-Auth (mirror of sentinel-mop-webhook-secret)
# RULES_PROVIDER=homegrown              # default; uncomment + change to enable MOP eval
