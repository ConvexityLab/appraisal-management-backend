# ─── Appraisal Management Backend — Environment Variables ────────────────────
#
# Copy this file to .env and fill in the values for your environment.
# All Azure SDK clients use Managed Identity (DefaultAzureCredential) in
# production — no keys or connection strings.
#
# Required variables are marked [REQUIRED]. Optional are marked [OPTIONAL].
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development                   # development | production | test [REQUIRED]
PORT=3011                              # HTTP listen port [OPTIONAL — default: 3011]

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Managed Identity is used in production. For local dev with Azurite use the
# emulator endpoint below.
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443    # [REQUIRED]
# AZURE_COSMOS_ENDPOINT=                                      # alias accepted by cosmos-db.service.ts

# ── Azure Managed Identity ────────────────────────────────────────────────────
# Set AZURE_CLIENT_ID if a user-assigned managed identity is needed (optional
# when system-assigned identity is configured).
# AZURE_CLIENT_ID=<object-id-of-user-assigned-managed-identity>

# ── Azure Service Bus ─────────────────────────────────────────────────────────
AZURE_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net   # [REQUIRED]
# USE_MOCK_SERVICE_BUS=true    # set to 'true' in development to skip real SB

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=<storage-account-name>   # [REQUIRED for document upload]
STORAGE_CONTAINER_DOCUMENTS=documents               # [OPTIONAL — default: documents]
BULK_UPLOAD_STORAGE_ACCOUNT_NAME=<bulk-upload-storage-account>  # [REQUIRED for bulk ingestion]

# ── Azure Key Vault ───────────────────────────────────────────────────────────
KEY_VAULT_URL=https://<vault-name>.vault.azure.net   # [REQUIRED for collaboration features]

# ── Property Data Enrichment ──────────────────────────────────────────────────
# At least one provider should be configured for subject property enrichment.
# When BOTH are set the service chains them: Bridge is tried first (MLS data),
# then ATTOM as a public-records fallback when Bridge returns no result.
# When neither is set enrichment is skipped (NullPropertyDataProvider warns).

# Bridge Interactive — provides MLS-linked data (AVM, public records)
# BRIDGE_SERVER_TOKEN=<your-bridge-interactive-server-token>

# ATTOM Data Solutions — 155M+ property public records (APN, assessment, flood)
# Only needed if calling the live ATTOM API. The property-data-cache is checked first;
# a missing key only causes failures on cache misses, not on cache hits.
# ATTOM_API_KEY=<your-attom-api-key>

# ── Property Data Cache (Cosmos: property-data-cache container) ───────────────
# How many days a cached property record is considered fresh before the live API
# is called to refresh it. Set to 0 (default) to never auto-refresh (cache forever).
ATTOM_CACHE_TTL_DAYS=0   # [OPTIONAL — default: 0 (never expire)]

# ── ATTOM CSV Ingestion (src/scripts/ingest-attom-csv.ts) ────────────────────
# Run once (and idempotently) to populate property-data-cache from the ATTOM
# CSV files stored in Azure Blob.
ATTOM_CSV_STORAGE_ACCOUNT=apprdev7iqxpvst         # [REQUIRED for ingestion]
ATTOM_CSV_CONTAINER=attom-data                     # [OPTIONAL — default: attom-data]
ATTOM_CSV_BLOBS=Duval_FL_2025_2026.csv,LA_2025_2026.csv  # [OPTIONAL — default: both FL+LA]
# ATTOM_CSV_BATCH_SIZE=100                         # [OPTIONAL — records per Cosmos batch]
# ATTOM_CSV_DRY_RUN=true                           # [OPTIONAL — parse without writing]

# How many days to consider an enrichment record "fresh" before re-fetching.
# Set to 0 to disable caching (always re-fetch).
ENRICHMENT_CACHE_TTL_DAYS=30   # [OPTIONAL — default: 30]

# ── Bulk Ingestion ────────────────────────────────────────────────────────────
BULK_INGESTION_DOCUMENT_UPLOAD_CONCURRENCY=16   # [OPTIONAL — default: 16]
