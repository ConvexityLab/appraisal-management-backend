      <tr>
        <td>Subject</td>
        <td>{{subject.fullAddress}}</td>
        <td>&mdash;</td>
        <td>&mdash;</td>
        <td><b>{{incomeApproach.estimatedMonthlyMarketRent}}</b></td>
        <td>{{subject.bedrooms}}/{{subject.bathrooms}}, {{subject.grossLivingArea}} sf</td>
        <td>&mdash;</td>
      </tr>
