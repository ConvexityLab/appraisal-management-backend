      <span class="weight-lbl">Sales Comparison</span>
      <div class="weight-track"><div class="weight-fill" style="width:{{reconciliation.salesCompWeightPct}}"></div></div>
      <span class="weight-pct">{{reconciliation.salesCompWeightPct}}</span>
    </div>
    <div class="weight-row">
      <span class="weight-lbl">Cost Approach</span>
      <div class="weight-track"><div class="weight-fill" style="width:{{reconciliation.costWeightPct}}"></div></div>
      <span class="weight-pct">{{reconciliation.costWeightPct}}</span>
    </div>
    <div class="weight-row">
      <span class="weight-lbl">Income Approach</span>
      <div class="weight-track"><div class="weight-fill" style="width:{{reconciliation.incomeWeightPct}}"></div></div>
      <span class="weight-pct">{{reconciliation.incomeWeightPct}}</span>
    </div>
    {{#if reconciliation.confidenceScore}}
    <div style="margin-top:4px;display:flex;align-items:center;gap:10px">
      <span style="font-size:7pt;color:var(--muted)">{{#if reconciliation.approachSpreadPct}}Approach spread: {{reconciliation.approachSpreadPct}} &nbsp;|&nbsp; {{/if}}Confidence:</span>
      <span class="conf-badge {{reconciliation.confidenceClass}}">{{#if reconciliation.confidenceScore}}{{reconciliation.confidenceScore}} / 100{{else}}&mdash;{{/if}}</span>
    </div>
    {{/if}}
  </div>
  {{/if}}

  <div class="row g2">
    <div class="cell"><span class="lbl">Reconciliation Comments</span>
      <span class="val">{{reconciliation.reconciliationNarrative}}</span>
    </div>
    <div class="cell">
      <div class="opinion-box">
        <div>
          <div class="opinion-label">Opinion of Market Value</div>
          <div class="opinion-date">Effective Date: {{reconciliation.effectiveDate}}</div>
