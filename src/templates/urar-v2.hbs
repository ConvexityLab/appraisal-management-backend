  {{#if hasHbu}}
  <div class="section-hdr">Highest &amp; Best Use &mdash; UAD 3.6 Four-Test Framework</div>
  <table class="hbu-table">
    <thead>
      <tr>
        <th style="width:35%">Test</th>
        <th style="width:22%">As Vacant</th>
        <th style="width:22%">As Improved</th>
        <th style="width:21%">Conclusion</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><b>1. Legally Permissible</b><br><span style="color:var(--muted);font-size:6.5pt">Zoning, deed restrictions, flood zone</span></td>
        <td>
          {{#if hbu.asVacant.legallyPermissible.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asVacant.legallyPermissible.narrative}}</span>
        </td>
        <td>
          {{#if hbu.asImproved.legallyPermissible.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asImproved.legallyPermissible.narrative}}</span>
        </td>
        <td>{{hbu.asVacant.legallyPermissible.evidence}}</td>
      </tr>
      <tr>
        <td><b>2. Physically Possible</b><br><span style="color:var(--muted);font-size:6.5pt">Size, shape, utilities, topography</span></td>
        <td>
          {{#if hbu.asVacant.physicallyPossible.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asVacant.physicallyPossible.narrative}}</span>
        </td>
        <td>
          {{#if hbu.asImproved.physicallyPossible.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asImproved.physicallyPossible.narrative}}</span>
        </td>
        <td>{{hbu.asVacant.physicallyPossible.evidence}}</td>
      </tr>
      <tr>
        <td><b>3. Financially Feasible</b><br><span style="color:var(--muted);font-size:6.5pt">Market demand, investment return</span></td>
        <td>
          {{#if hbu.asVacant.financiallyFeasible.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asVacant.financiallyFeasible.narrative}}</span>
        </td>
        <td>
          {{#if hbu.asImproved.financiallyFeasible.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asImproved.financiallyFeasible.narrative}}</span>
        </td>
        <td>{{hbu.asVacant.financiallyFeasible.evidence}}</td>
      </tr>
      <tr>
        <td><b>4. Maximally Productive</b><br><span style="color:var(--muted);font-size:6.5pt">Highest return among legal, physical, feasible uses</span></td>
        <td>
          {{#if hbu.asVacant.maximallyProductive.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asVacant.maximallyProductive.narrative}}</span>
        </td>
        <td>
          {{#if hbu.asImproved.maximallyProductive.passed}}<span class="hbu-pass">&#10003; Pass</span>{{else}}<span class="hbu-fail">&#10005; Fail</span>{{/if}}
          <br><span style="font-size:6.5pt">{{hbu.asImproved.maximallyProductive.narrative}}</span>
        </td>
        <td><b>{{hbu.asVacant.maximallyProductive.evidence}}</b></td>
      </tr>
    </tbody>
  </table>
  <div style="font-size:7.5pt;margin-top:4px;padding:4px 8px;background:var(--gold-bg);border-radius:3px">
    <b>H&amp;BU Conclusion:</b> {{hbu.conclusion}}
  </div>
  {{/if}}

  <div class="section-hdr">Prior Sales History &mdash; Subject &amp; Comparables (3-Year)</div>
