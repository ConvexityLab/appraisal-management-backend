    <div class="cell"><span class="lbl">Indicated Monthly Gross Rent</span><span class="val">{{incomeApproach.estimatedMonthlyMarketRent}} / mo</span></div>
    <div class="cell"><span class="lbl">Gross Rent Multiplier</span><span class="val">{{incomeApproach.grossRentMultiplier}}</span></div>
    <div class="cell"><span class="lbl">Indicated Value by Income</span><span class="val" style="font-size:10pt;font-weight:800;color:var(--navy)">{{incomeApproach.indicatedValueByIncomeApproach}}</span></div>
  </div>
  <div class="row g4">
    <div class="cell"><span class="lbl">Vacancy &amp; Loss Rate</span><span class="val">{{incomeApproach.vacancyRate}}</span></div>
    <div class="cell"><span class="lbl">Potential Gross Income</span><span class="val">{{incomeApproach.potentialGrossIncome}} / yr</span></div>
    <div class="cell"><span class="lbl">Effective Gross Income</span><span class="val">{{incomeApproach.effectiveGrossIncome}} / yr</span></div>
    <div class="cell"><span class="lbl">Net Operating Income</span><span class="val">{{incomeApproach.netOperatingIncome}} / yr</span></div>
  </div>
  {{#if hasRentComps}}
