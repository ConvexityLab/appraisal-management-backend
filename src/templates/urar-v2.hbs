        <th>Effective Date</th>
        <th>Opinion of Value</th>
        <th>Applicable Premise / Condition</th>
      </tr>
    </thead>
    <tbody>
      {{#each valueTypesBlock}}
      <tr>
        <td><span class="vt-{{this.vtClass}}" style="padding:1px 6px;border-radius:3px;font-size:6.5pt">{{this.valueType}}</span></td>
        <td>{{this.effectiveDate}}</td>
        <td style="font-weight:800;color:var(--navy)">{{this.indicatedValue}}</td>
        <td>{{this.notes}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  <div class="page-footer">
    <span class="page-footer-left">Uniform Residential Appraisal Report &bull; File {{metadata.orderNumber}} &bull; Page 3 of 4</span>
    <span class="page-footer-brand">VISION <span>VMC</span> &bull; Real Estate Valuation Experts</span>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     PAGE 4 — Appraiser Certification, Signatures, Aerial, Lender
═══════════════════════════════════════════════════════════════════ -->
<div class="page">

  <div class="brand-bar">
    <div class="brand-left">
      <div class="brand-name">VISION <span>VMC</span></div>
      <div class="brand-sub">Real Estate Valuation Experts &bull; Licensed Nationally</div>
    </div>
    <div class="brand-badges">
      <span class="brand-badge">Certification &amp; Signatures</span>
      <span class="brand-contact">File No. {{metadata.orderNumber}}</span>
    </div>
  </div>

  <div class="section-hdr">Appraiser Certification</div>
  <div style="font-size:7.5pt;line-height:1.65;padding:6px 8px;background:#FAFBFC;border:1px solid var(--border);border-radius:3px;margin-bottom:6px">
    I certify that, to the best of my knowledge and belief:
    The statements of fact contained in this report are true and correct. The reported analyses, opinions, and conclusions are limited only by the reported assumptions and limiting conditions and are my personal, impartial, and unbiased professional analyses, opinions, and conclusions. I have no present or prospective interest in the property that is the subject of this report and no personal interest with respect to the parties involved. I have performed no services, as an appraiser or in any other capacity, regarding the property that is the subject of this report within the three-year period immediately preceding acceptance of this assignment. I have no bias with respect to the property that is the subject of this report or the parties involved. <b>The appraisal was performed in conformance with the Uniform Standards of Professional Appraisal Practice (USPAP), UAD 3.6, and applicable Fannie Mae/Freddie Mac guidelines.</b>
  </div>

  <div class="section-hdr">Scope of Work</div>
  <div style="font-size:7.5pt;line-height:1.6;padding:5px 8px;background:#F8FAFC;border:1px solid var(--border);border-radius:3px;margin-bottom:6px">
    Interior and exterior inspection performed {{metadata.inspectionDate}}. Public records searched. MLS sales data reviewed. Sales Comparison{{#if hasCostApproach}}, Cost{{/if}}{{#if hasIncomeApproach}}, and Income Approaches{{else}} Approach{{/if}} developed. Market conditions analyzed per Fannie Mae Market Conditions Addendum guidance.
  </div>

  <div class="section-hdr">Appraiser Signature</div>
  {{#if appraiser}}
  <div class="sig-block">
    <div class="sig-label">Appraiser Signature</div>
    <div class="sig-name">{{appraiser.name}}</div>
    <div class="sig-grid">
      <div class="sig-item"><b>Name:</b> {{appraiser.name}}</div>
      <div class="sig-item"><b>Company:</b> {{appraiser.companyName}}</div>
      <div class="sig-item"><b>Date Signed:</b> {{appraiser.signatureDate}}</div>
      <div class="sig-item"><b>License Type:</b> {{appraiser.licenseType}}</div>
      <div class="sig-item"><b>State Cert / Lic #:</b> {{appraiser.licenseNumber}}</div>
      <div class="sig-item"><b>State:</b> {{appraiser.licenseState}}</div>
      <div class="sig-item"><b>Expiration:</b> {{appraiser.licenseExpirationDate}}</div>
      {{#if appraiser.phone}}<div class="sig-item"><b>Phone:</b> {{appraiser.phone}}</div>{{/if}}
      {{#if appraiser.email}}<div class="sig-item"><b>Email:</b> {{appraiser.email}}</div>{{/if}}
      {{#if appraiser.companyAddress}}<div class="sig-item" style="grid-column:span 3"><b>Address:</b> {{appraiser.companyAddress}}</div>{{/if}}
    </div>
  </div>
  {{/if}}

  <div class="section-hdr">Supervisory Appraiser (if applicable)</div>
  {{#if appraiser.supervisory}}
  <div class="sig-block">
    <div class="sig-label">Supervisory Appraiser Signature</div>
    <div class="sig-name">{{appraiser.supervisory.name}}</div>
    <div class="sig-grid">
      <div class="sig-item"><b>Name:</b> {{appraiser.supervisory.name}}</div>
      <div class="sig-item"><b>Company:</b> {{appraiser.supervisory.companyName}}</div>
      <div class="sig-item"><b>Date Signed:</b> {{appraiser.supervisory.signatureDate}}</div>
      <div class="sig-item"><b>State Cert / Lic #:</b> {{appraiser.supervisory.licenseNumber}}</div>
      <div class="sig-item"><b>State:</b> {{appraiser.supervisory.licenseState}}</div>
      <div class="sig-item"><b>Expiration:</b> {{appraiser.supervisory.licenseExpirationDate}}</div>
    </div>
  </div>
  {{else}}
  <div class="sig-block" style="background:#FAF8F5">
    <div class="sig-label">Supervisory Appraiser Signature (Required for non-certified appraiser trainees only)</div>
    <div class="sig-name">&mdash; Not Applicable &mdash;</div>
    <div style="font-size:7pt;color:var(--muted)">Signing appraiser holds state-certified residential classification; supervisory signature not required.</div>
  </div>
  {{/if}}

  <div class="section-hdr">Lender / Client &amp; Intended Use</div>
  <div class="row g2">
    <div class="cell">
      <span class="lbl">Lender / Client Name</span>
      <span class="val">{{metadata.clientCompanyName}}</span>
    </div>
    <div class="cell">
      <span class="lbl">Client Address</span>
      <span class="val">{{metadata.clientAddress}}</span>
    </div>
  </div>
  <div class="row g2">
    <div class="cell">
      <span class="lbl">Loan Number</span>
      <span class="val">{{metadata.loanNumber}}</span>
    </div>
    <div class="cell">
      <span class="lbl">Client Email</span>
      <span class="val">{{metadata.clientEmail}}</span>
    </div>
  </div>

  <div class="section-hdr gold">Aerial / Location Map</div>
  {{#if photos.aerial}}
  <div style="border:1px solid var(--border);border-radius:4px;overflow:hidden;margin:4px 0">
    <img src="{{photos.aerial.dataUri}}" alt="Aerial Map" style="width:100%;height:130px;object-fit:cover;display:block"/>
  </div>
  {{else}}
  <div style="border:1px solid var(--border);border-radius:4px;height:130px;background:linear-gradient(135deg,#C8D8EC 0%,#D9E8D4 50%,#E8EFF7 100%);display:flex;align-items:center;justify-content:center;margin:4px 0">
    <div style="text-align:center">
      <div style="font-size:9pt;font-weight:700;color:var(--navy)">Aerial Photograph / Location Map</div>
      <div style="font-size:7.5pt;color:var(--navy-mid);margin-top:3px">{{subject.fullAddress}}</div>
      <div style="font-size:7pt;color:var(--muted);margin-top:2px">[Satellite imagery &ndash; attached separately in production render]</div>
    </div>
  </div>
  {{/if}}

  <div class="section-hdr">Addenda Attached</div>
  <div class="row g2">
    <div class="cell" style="font-size:7.5pt;line-height:2">
      &#10003; Market Conditions Addendum (Form 1004MC)<br>
      &#10003; Subject Interior Photographs<br>
      &#10003; Flood Certification<br>
      &#10003; License Certificate &mdash; {{appraiser.name}}
    </div>
    <div class="cell" style="font-size:7.5pt;line-height:2">
      &#10003; Plat Map<br>
      &#10003; Comparable Location Map<br>
      &#10003; Appraiser Comments &amp; Limiting Conditions<br>
      {{#if hasEA}}&#10003; Extraordinary Assumptions Documentation{{/if}}
    </div>
  </div>

  <div style="margin-top:10px;background:var(--navy);color:#fff;padding:10px 14px;border-radius:4px;display:flex;align-items:center;justify-content:space-between">
    <div>
      <div style="font-size:13pt;font-weight:800;letter-spacing:.08em">VISION <span style="color:var(--gold)">VMC</span></div>
      <div style="font-size:7pt;color:#B8C9E0;letter-spacing:.1em;text-transform:uppercase;margin-top:2px">Real Estate Valuation Experts &bull; Licensed Nationally</div>
    </div>
    <div style="text-align:right;font-size:7pt;color:#B8C9E0;line-height:1.7">
      425 Town Plaza Ave., Ponte Vedra, FL 32081<br>
      info@visionvmc.com<br>
      File No. {{metadata.orderNumber}} &bull; UAD 3.6<br>
      Generated: {{generatedAt}}
    </div>
  </div>

  <div class="page-footer" style="margin-top:6px">
    <span class="page-footer-left">Uniform Residential Appraisal Report &bull; File {{metadata.orderNumber}} &bull; Page 4 of 4</span>
    <span class="page-footer-brand">VISION <span>VMC</span> &bull; Real Estate Valuation Experts</span>
  </div>
</div>

</body>
</html>