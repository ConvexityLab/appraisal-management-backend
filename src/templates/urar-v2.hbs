        <td>Rental Comp </td>
        <td>{{this.address}}</td>
        <td>{{this.proximityToSubject}}</td>
        <td>{{this.monthlyRent}}</td>
        <td>{{this.adjustedRent}}</td>
        <td>{{this.propertyDescription}}</td>
        <td>{{this.dataSource}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}
  {{/if}}

  <div class="section-hdr">Reconciliation &amp; Final Value</div>
