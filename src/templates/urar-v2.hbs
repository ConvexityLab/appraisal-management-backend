<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>URAR Form 1004 — {{metadata.orderNumber}} — Vision VMC</title>
<style>
  :root{
    --navy:#0C2340; --navy-mid:#163D6B; --navy-light:#1F5499;
    --gold:#C49A1A; --gold-bg:#FBF5E0; --gold-light:#F7ECC8;
    --text:#1A1A1A; --muted:#6B7280; --border:#CBD5E1;
    --green:#155F2A; --red:#9B1C1C; --page-w:8.5in;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:#E5E7EB;font-family:'Segoe UI',Arial,sans-serif;font-size:8pt;color:var(--text);print-color-adjust:exact}
  .page{width:var(--page-w);min-height:11in;background:#fff;margin:0 auto 32px;padding:0.45in 0.5in 0.4in;box-shadow:0 4px 24px rgba(0,0,0,.15);page-break-after:always}
  @media print{.page{margin:0;box-shadow:none}}
  .brand-bar{background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:space-between;padding:8px 14px;margin:0 -0.5in 10px;width:calc(100% + 1in);border-bottom:3px solid var(--gold)}
  .brand-left{display:flex;flex-direction:column}
  .brand-name{font-size:15pt;font-weight:800;letter-spacing:.08em;color:#fff}
  .brand-name span{color:var(--gold)}
  .brand-sub{font-size:7.5pt;color:#B8C9E0;letter-spacing:.12em;text-transform:uppercase;margin-top:1px}
  .brand-badges{display:flex;flex-direction:column;align-items:flex-end;gap:3px}
  .brand-badge{font-size:6.5pt;color:var(--gold-light);letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(196,154,26,.45);padding:1px 6px;border-radius:10px}
  .brand-contact{font-size:6.5pt;color:#B8C9E0;margin-top:2px}
  .form-title-bar{background:var(--gold);color:var(--navy);text-align:center;padding:5px 0;margin-bottom:8px;border-radius:2px}
  .form-title-bar h1{font-size:11pt;font-weight:800;letter-spacing:.04em;text-transform:uppercase}
  .form-title-bar p{font-size:7.5pt;font-weight:600;color:var(--navy-mid);margin-top:1px}
  .section-hdr{background:var(--navy);color:#fff;font-size:7.5pt;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:3px 8px;margin:7px 0 3px;border-left:4px solid var(--gold)}
  .section-hdr.gold{background:var(--gold-bg);color:var(--navy);border-left:4px solid var(--gold)}
  .row{display:grid;gap:0;margin-bottom:0}
  .g2{grid-template-columns:1fr 1fr}
  .g3{grid-template-columns:1fr 1fr 1fr}
  .g4{grid-template-columns:repeat(4,1fr)}
  .cell{border:1px solid var(--border);padding:2px 5px;line-height:1.4}
  .cell+.cell{border-left:none}
  .lbl{font-size:6.5pt;color:var(--muted);font-weight:600;text-transform:uppercase;display:block;margin-bottom:1px}
  .val{font-size:8pt;color:var(--text)}
  .photo-row{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin:6px 0}
  .photo-box{border:1px solid var(--border);border-radius:3px;overflow:hidden;background:#F1F5F9}
  .photo-box img{width:100%;height:100px;object-fit:cover;display:block}
  .photo-cap{font-size:6.5pt;text-align:center;color:var(--muted);padding:2px 0;border-top:1px solid var(--border)}
  .comp-table{width:100%;border-collapse:collapse;font-size:7pt;margin-top:4px}
  .comp-table th{background:var(--navy);color:#fff;padding:3px 5px;text-align:left;font-size:6.5pt;font-weight:700;text-transform:uppercase;border:1px solid var(--navy-mid)}
  .comp-table td{border:1px solid var(--border);padding:2px 5px;vertical-align:top}
  .comp-table tr:nth-child(even) td{background:#F8FAFC}
  .comp-hdr-gold td{background:var(--gold-bg)!important;font-weight:700;font-size:7pt;color:var(--navy)}
  .adj-p{color:var(--green);font-weight:700}
  .adj-n{color:var(--red);font-weight:700}
  .fin-val{background:var(--gold-bg);font-weight:800;color:var(--navy);font-size:8pt}
  .hbu-table{width:100%;border-collapse:collapse;font-size:7pt;margin-top:4px}
  .hbu-table th{background:var(--navy-mid);color:#fff;padding:3px 6px;font-size:6.5pt;font-weight:700;text-transform:uppercase;border:1px solid var(--border)}
  .hbu-table td{border:1px solid var(--border);padding:3px 6px}
  .hbu-pass{color:var(--green);font-weight:700}
  .hbu-fail{color:var(--red);font-weight:700}
  .hbu-na{color:var(--muted)}
  .weight-row{display:flex;align-items:center;gap:8px;margin:3px 0}
  .weight-lbl{font-size:7pt;color:var(--navy);font-weight:700;width:130px;flex-shrink:0}
  .weight-track{flex:1;height:10px;background:#E5E7EB;border-radius:4px;overflow:hidden}
  .weight-fill{height:100%;border-radius:4px;background:var(--navy-light)}
  .weight-pct{font-size:7pt;font-weight:700;color:var(--navy);width:30px;text-align:right}
  .conf-badge{display:inline-block;padding:3px 12px;border-radius:12px;font-size:7.5pt;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin:4px 0}
  .conf-high{background:#DCFCE7;color:var(--green);border:1px solid #86EFAC}
  .conf-medium{background:#FEF9C3;color:#854D0E;border:1px solid #FDE047}
  .conf-low{background:#FEE2E2;color:var(--red);border:1px solid #FCA5A5}
  .opinion-box{border:2px solid var(--gold);background:var(--gold-bg);padding:8px 14px;margin:6px 0;border-radius:4px;display:flex;align-items:baseline;justify-content:space-between}
  .opinion-label{font-size:8pt;font-weight:700;color:var(--navy);text-transform:uppercase}
  .opinion-value{font-size:18pt;font-weight:900;color:var(--navy);letter-spacing:.04em}
  .opinion-date{font-size:7.5pt;color:var(--navy-mid)}
  .disclosure-box{border-left:4px solid var(--gold);background:var(--gold-bg);padding:6px 10px;margin:5px 0;border-radius:0 4px 4px 0}
  .disclosure-box.hc{border-left-color:#9B1C1C;background:#FFF0F0}
  .disclosure-hdr{font-size:7.5pt;font-weight:800;text-transform:uppercase;color:var(--navy);margin-bottom:2px}
  .disclosure-box.hc .disclosure-hdr{color:#7F1D1D}
  .disclosure-item{font-size:7.5pt;color:var(--text);margin:1px 0;padding-left:10px}
  .disclosure-item::before{content:"▸ ";color:var(--gold);font-size:7pt}
  .disclosure-box.hc .disclosure-item::before{color:#9B1C1C}
  .vt-table{width:100%;border-collapse:collapse;font-size:7.5pt;margin-top:4px}
  .vt-table th{background:var(--navy);color:#fff;padding:3px 8px;font-size:6.5pt;font-weight:700;text-transform:uppercase;border:1px solid var(--border)}
  .vt-table td{border:1px solid var(--border);padding:3px 8px}
  .vt-as-is{background:#EFF6FF;font-weight:700}
  .vt-as-repaired{background:#F0FDF4;font-weight:700}
  .vt-as-completed{background:var(--gold-bg);font-weight:700}
  .vt-retrospective{background:#F5F0FF;font-weight:700}
  .vt-prospective{background:#FFF7F0;font-weight:700}
  .rent-table{width:100%;border-collapse:collapse;font-size:7pt;margin-top:4px}
  .rent-table th{background:var(--navy-light);color:#fff;padding:3px 5px;font-size:6.5pt;font-weight:700;text-transform:uppercase;border:1px solid var(--border)}
  .rent-table td{border:1px solid var(--border);padding:2px 5px}
  .rent-table tr:nth-child(even) td{background:#F8FAFC}
  .sig-block{border:1px solid var(--border);padding:7px 10px;margin:5px 0;border-radius:3px;background:#FAFBFC}
  .sig-label{font-size:6.5pt;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;font-weight:700;margin-bottom:1px}
  .sig-name{font-size:9pt;font-weight:700;color:var(--navy);font-style:italic;border-bottom:1px solid var(--border);margin-bottom:4px;padding-bottom:4px}
  .sig-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}
  .sig-item{font-size:7pt}
  .sig-item b{color:var(--navy)}
  .page-footer{border-top:2px solid var(--navy);margin-top:6px;padding-top:4px;display:flex;justify-content:space-between;align-items:center}
  .page-footer-left{font-size:6.5pt;color:var(--muted)}
  .page-footer-brand{font-size:7pt;font-weight:700;color:var(--navy);letter-spacing:.06em}
  .page-footer-brand span{color:var(--gold)}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════
     PAGE 1 — Subject, Neighborhood, Site, Improvements, Photos
═══════════════════════════════════════════════════════════════════ -->
<div class="page">

  <div class="brand-bar">
    <div class="brand-left">
      <div class="brand-name">VISION <span>VMC</span></div>
      <div class="brand-sub">Real Estate Valuation Experts &bull; Licensed Nationally</div>
    </div>
    <div class="brand-badges">
      <span class="brand-badge">Uniform Residential Appraisal Report</span>
      <span class="brand-badge">UAD 3.6 Compliant</span>
      {{#if metadata.hasAxiomRef}}
      <span class="brand-badge" style="color:#B8C9E0;border-color:rgba(196,154,26,.3)">AI Ref: {{metadata.axiomEvaluationId}}{{#if metadata.axiomCompletedAt}} &bull; {{metadata.axiomCompletedAt}}{{/if}}</span>
      {{/if}}
      <span class="brand-contact">info@visionvmc.com &bull; 425 Town Plaza Ave., Ponte Vedra, FL 32081</span>
    </div>
  </div>

  <div class="form-title-bar">
    <h1>Uniform Residential Appraisal Report &mdash; Form 1004</h1>
    <p>File No. {{metadata.orderNumber}} &bull; UAD Edition &bull; Fannie Mae / Freddie Mac Compliant</p>
  </div>

  <div class="section-hdr">Subject</div>
  <div class="row g2">
    <div class="cell">
      <span class="lbl">Property Address</span>
      <span class="val">{{subject.fullAddress}}</span>
    </div>
    <div class="cell">
      <span class="lbl">Legal Description</span>
      <span class="val">{{subject.legalDescription}}</span>
    </div>
  </div>
  <div class="row g4">
    <div class="cell"><span class="lbl">City</span><span class="val">{{subject.city}}</span></div>
    <div class="cell"><span class="lbl">County</span><span class="val">{{subject.county}}</span></div>
    <div class="cell"><span class="lbl">State</span><span class="val">{{subject.state}}</span></div>
    <div class="cell"><span class="lbl">Zip</span><span class="val">{{subject.zipCode}}</span></div>
  </div>
  <div class="row g3">
    <div class="cell"><span class="lbl">Borrower</span><span class="val">{{metadata.borrowerName}}</span></div>
    <div class="cell"><span class="lbl">Owner of Public Record</span><span class="val">{{metadata.ownerOfPublicRecord}}</span></div>
    <div class="cell"><span class="lbl">Census Tract</span><span class="val">{{subject.censusTract}}</span></div>
  </div>
  <div class="row g4">
    <div class="cell"><span class="lbl">Occupant</span><span class="val">{{subject.occupant}}</span></div>
    <div class="cell"><span class="lbl">Special Assessments / Taxes</span><span class="val">{{subject.annualTaxes}}</span></div>
    <div class="cell"><span class="lbl">Parcel Number</span><span class="val">{{subject.parcelNumber}}</span></div>
    <div class="cell"><span class="lbl">Map Reference</span><span class="val">{{subject.mapReference}}</span></div>
  </div>

  <div class="section-hdr">Neighborhood Characteristics</div>
  <div class="row g3">
    <div class="cell">
      <span class="lbl">Location</span>
      <div style="font-size:7.5pt;line-height:1.9">
        {{#if market.isUrban}}<span style="color:var(--navy);font-weight:700">&#10003; Urban</span>{{else}}Urban{{/if}}
        &nbsp;
        {{#if market.isSuburban}}<span style="color:var(--navy);font-weight:700">&#10003; Suburban</span>{{else}}Suburban{{/if}}
        &nbsp;
        {{#if market.isRural}}<span style="color:var(--navy);font-weight:700">&#10003; Rural</span>{{else}}Rural{{/if}}
      </div>
    </div>
    <div class="cell">
      <span class="lbl">Built-Up</span>
      <div style="font-size:7.5pt;line-height:1.9">
        {{#if market.isOver75}}<span style="color:var(--navy);font-weight:700">&#10003; Over 75%</span>{{else}}Over 75%{{/if}}
        &nbsp;
        {{#if market.is25to75}}<span style="color:var(--navy);font-weight:700">&#10003; 25-75%</span>{{else}}25-75%{{/if}}
        &nbsp;
        {{#if market.isUnder25}}<span style="color:var(--navy);font-weight:700">&#10003; Under 25%</span>{{else}}Under 25%{{/if}}
      </div>
    </div>
    <div class="cell">
      <span class="lbl">Growth</span>
      <div style="font-size:7.5pt;line-height:1.9">
        {{#if market.isRapid}}<span style="color:var(--navy);font-weight:700">&#10003; Rapid</span>{{else}}Rapid{{/if}}
        &nbsp;
        {{#if market.isGrowthStable}}<span style="color:var(--navy);font-weight:700">&#10003; Stable</span>{{else}}Stable{{/if}}
        &nbsp;
        {{#if market.isSlow}}<span style="color:var(--navy);font-weight:700">&#10003; Slow</span>{{else}}Slow{{/if}}
      </div>
    </div>
  </div>
  <div class="row g4">
    <div class="cell"><span class="lbl">Property Values</span><span class="val">
      {{#if market.isIncreasing}}<span style="color:var(--navy);font-weight:700">&#10003; Increasing</span>{{else}}Increasing{{/if}}
      &nbsp;
      {{#if market.isStable}}<span style="color:var(--navy);font-weight:700">&#10003; Stable</span>{{else}}Stable{{/if}}
      &nbsp;
      {{#if market.isDeclining}}<span style="color:var(--navy);font-weight:700">&#10003; Declining</span>{{else}}Declining{{/if}}
    </span></div>
    <div class="cell"><span class="lbl">Price Range</span><span class="val">{{market.priceLow}} &ndash; {{market.priceHigh}}</span></div>
    <div class="cell"><span class="lbl">Predominant Age</span><span class="val">{{market.predominantAge}}</span></div>
    <div class="cell"><span class="lbl">Neighborhood Bounds</span><span class="val">{{market.boundaryDescription}}</span></div>
  </div>
  <div class="row g2">
    <div class="cell">
      <span class="lbl">Neighborhood Description</span>
      <span class="val">{{market.neighborhoodDescription}}</span>
    </div>
    <div class="cell">
      <span class="lbl">Market Conditions</span>
      <span class="val">{{market.marketConditionsNotes}}</span>
    </div>
  </div>

  <div class="section-hdr">Site</div>
  <div class="row g4">
    <div class="cell"><span class="lbl">Area (sq ft)</span><span class="val">{{subject.lotSizeSqFt}}</span></div>
    <div class="cell"><span class="lbl">Shape</span><span class="val">{{subject.siteShape}}</span></div>
    <div class="cell"><span class="lbl">View</span><span class="val">{{subject.view}}</span></div>
    <div class="cell"><span class="lbl">Specific Zoning</span><span class="val">{{subject.zoning}}</span></div>
  </div>
  <div class="row g3">
    <div class="cell"><span class="lbl">Utilities &mdash; Electric</span><span class="val">{{subject.utilities.electricity}}</span></div>
    <div class="cell"><span class="lbl">Water</span><span class="val">{{subject.utilities.water}}</span></div>
    <div class="cell"><span class="lbl">Sanitary Sewer</span><span class="val">{{subject.utilities.sewer}}</span></div>
  </div>
  <div class="row g2">
    <div class="cell"><span class="lbl">Flood Zone</span><span class="val">{{subject.floodZone}}</span></div>
    <div class="cell"><span class="lbl">FEMA Map / Date</span><span class="val">{{subject.floodMapNumber}} / {{subject.floodMapDate}}</span></div>
  </div>

  <div class="section-hdr">Improvements</div>
  <div class="row g4">
    <div class="cell"><span class="lbl">Year Built</span><span class="val">{{subject.yearBuilt}}</span></div>
    <div class="cell"><span class="lbl">Effective Age</span><span class="val">{{subject.effectiveAge}} yrs</span></div>
    <div class="cell"><span class="lbl">GLA (sq ft)</span><span class="val">{{subject.grossLivingArea}}</span></div>
    <div class="cell"><span class="lbl">Total Rooms</span><span class="val">{{subject.totalRooms}}</span></div>
  </div>
  <div class="row g4">
    <div class="cell"><span class="lbl">Bedrooms</span><span class="val">{{subject.bedrooms}}</span></div>
    <div class="cell"><span class="lbl">Bathrooms</span><span class="val">{{subject.bathrooms}}</span></div>
    <div class="cell"><span class="lbl">Garage / Carport</span><span class="val">{{subject.garageType}}{{#if subject.garageSpaces}} ({{subject.garageSpaces}}-Car){{/if}}</span></div>
    <div class="cell"><span class="lbl">Basement</span><span class="val">{{subject.basement}}</span></div>
  </div>
  <div class="row g2">
    <div class="cell"><span class="lbl">Foundation</span><span class="val">{{subject.foundationType}}</span></div>
    <div class="cell"><span class="lbl">Exterior Description</span><span class="val">{{subject.exteriorWalls}}; {{subject.roofSurface}}</span></div>
  </div>
  <div class="row g2">
    <div class="cell"><span class="lbl">Heating / Cooling</span><span class="val">{{subject.heating}}; {{subject.cooling}}</span></div>
    <div class="cell"><span class="lbl">Interior Finishes</span><span class="val">{{subject.interiorFloors}}; {{subject.interiorWalls}}</span></div>
  </div>
  <div class="row g2">
    <div class="cell"><span class="lbl">Condition</span><span class="val">{{subject.condition}}{{#if subject.conditionDescription}} &mdash; {{subject.conditionDescription}}{{/if}}</span></div>
    <div class="cell"><span class="lbl">Quality</span><span class="val">{{subject.quality}}</span></div>
  </div>
  <div class="row g2">
    <div class="cell"><span class="lbl">Additional Features</span><span class="val">{{subject.additionalFeatures}}</span></div>
    <div class="cell"><span class="lbl">Pool / Porch / Patio / Deck</span><span class="val">Pool: {{subject.pool}}; {{subject.porchPatioDeck}}</span></div>
  </div>

  <div class="section-hdr gold">Subject Property Photos</div>
  <div class="photo-row">
    <div class="photo-box">
      {{#if photos.subjectFront}}
      <img src="{{photos.subjectFront.dataUri}}" alt="Subject Front" style="width:100%;height:100px;object-fit:cover;display:block"/>
      {{else}}
      <div style="height:100px;background:linear-gradient(135deg,#B8C9E0,#E8EFF7);display:flex;align-items:center;justify-content:center">
        <span style="font-size:7.5pt;color:var(--navy-mid);font-weight:600">Front Elevation</span>
      </div>
      {{/if}}
      <div class="photo-cap">Subject Front &bull; {{subject.streetAddress}}</div>
    </div>
    <div class="photo-box">
      {{#if photos.subjectRear}}
      <img src="{{photos.subjectRear.dataUri}}" alt="Subject Rear" style="width:100%;height:100px;object-fit:cover;display:block"/>
      {{else}}
      <div style="height:100px;background:linear-gradient(135deg,#D0E8D0,#EFF9EF);display:flex;align-items:center;justify-content:center">
        <span style="font-size:7.5pt;color:var(--navy-mid);font-weight:600">Rear Elevation</span>
      </div>
      {{/if}}
      <div class="photo-cap">Subject Rear &bull; {{subject.streetAddress}}</div>
    </div>
    <div class="photo-box">
      {{#if photos.subjectStreet}}
      <img src="{{photos.subjectStreet.dataUri}}" alt="Street Scene" style="width:100%;height:100px;object-fit:cover;display:block"/>
      {{else}}
      <div style="height:100px;background:linear-gradient(135deg,#E8E0D0,#F9F5EF);display:flex;align-items:center;justify-content:center">
        <span style="font-size:7.5pt;color:var(--navy-mid);font-weight:600">Street Scene</span>
      </div>
      {{/if}}
      <div class="photo-cap">Street Scene &bull; {{subject.streetAddress}}</div>
    </div>
  </div>

  <div class="page-footer">
    <span class="page-footer-left">Uniform Residential Appraisal Report &bull; File {{metadata.orderNumber}} &bull; Page 1 of 4</span>
    <span class="page-footer-brand">VISION <span>VMC</span> &bull; Real Estate Valuation Experts</span>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     PAGE 2 — Sales Comparison, Comp Photos, H&BU 4-Test
═══════════════════════════════════════════════════════════════════ -->
<div class="page">

  <div class="brand-bar">
    <div class="brand-left">
      <div class="brand-name">VISION <span>VMC</span></div>
      <div class="brand-sub">Real Estate Valuation Experts &bull; Licensed Nationally</div>
    </div>
    <div class="brand-badges">
      <span class="brand-badge">Sales Comparison &amp; H&amp;BU Analysis</span>
      <span class="brand-contact">File No. {{metadata.orderNumber}}</span>
    </div>
  </div>

  <div class="section-hdr">Sales Comparison Analysis</div>
  <table class="comp-table">
    <thead>
      <tr>
        <th style="width:28%">Feature</th>
        <th style="width:18%">Subject</th>
        <th style="width:18%">Comparable 1</th>
        <th style="width:18%">Comparable 2</th>
        <th style="width:18%">Comparable 3</th>
      </tr>
    </thead>
    <tbody>
      <tr class="comp-hdr-gold">
        <td><b>Address</b></td>
        <td>{{subject.fullAddress}}</td>
        <td>{{primaryComps.[0].fullAddress}}</td>
        <td>{{primaryComps.[1].fullAddress}}</td>
        <td>{{primaryComps.[2].fullAddress}}</td>
      </tr>
      <tr>
        <td>Sale Price</td>
        <td>&mdash;</td>
        <td>{{primaryComps.[0].salePrice}}</td>
        <td>{{primaryComps.[1].salePrice}}</td>
        <td>{{primaryComps.[2].salePrice}}</td>
      </tr>
      <tr>
        <td>Proximity to Subject</td>
        <td>&mdash;</td>
        <td>{{primaryComps.[0].proximityToSubject}}</td>
        <td>{{primaryComps.[1].proximityToSubject}}</td>
        <td>{{primaryComps.[2].proximityToSubject}}</td>
      </tr>
      <tr>
        <td>Sale Date</td>
        <td>&mdash;</td>
        <td>{{primaryComps.[0].saleDate}}</td>
        <td>{{primaryComps.[1].saleDate}}</td>
        <td>{{primaryComps.[2].saleDate}}</td>
      </tr>
      <tr>
        <td>Data Source</td>
        <td>&mdash;</td>
        <td>{{primaryComps.[0].dataSource}}</td>
        <td>{{primaryComps.[1].dataSource}}</td>
        <td>{{primaryComps.[2].dataSource}}</td>
      </tr>
      <tr>
        <td>Financing / COF</td>
        <td>&mdash;</td>
