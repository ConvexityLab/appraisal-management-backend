  <div style="border:1px solid var(--border);border-radius:4px;margin:4px 0;overflow:hidden">
    <div style="background:var(--gold-bg);border-bottom:1px solid var(--border);padding:3px 8px">
      <span style="font-size:7pt;font-weight:700;text-transform:uppercase;color:var(--navy);letter-spacing:.06em">Depreciation Breakdown (UAD 3.6)</span>
    </div>
    <div class="row g4" style="margin:0">
      <div class="cell" style="border:none;border-right:1px solid var(--border)"><span class="lbl">Physical &mdash; Curable</span><span class="val">{{costApproach.physicalDepreciationCurable}}</span></div>
      <div class="cell" style="border:none;border-right:1px solid var(--border)"><span class="lbl">Physical &mdash; Incurable</span><span class="val">{{costApproach.physicalDepreciationIncurable}}</span></div>
      <div class="cell" style="border:none;border-right:1px solid var(--border)"><span class="lbl">Functional Obsolescence</span><span class="val">{{costApproach.functionalObsolescence}}</span></div>
      <div class="cell" style="border:none"><span class="lbl">External Obsolescence</span><span class="val">{{costApproach.externalObsolescence}}</span></div>
    </div>
    <div class="row g3" style="margin:0">
      <div class="cell" style="border:none;border-top:1px solid var(--border);border-right:1px solid var(--border)"><span class="lbl">Depreciated Value of Improvements</span><span class="val"><b>{{costApproach.depreciatedCostOfImprovements}}</b></span></div>
      <div class="cell" style="border:none;border-top:1px solid var(--border);border-right:1px solid var(--border)"><span class="lbl">Effective Age</span><span class="val">{{costApproach.effectiveAge}} years</span></div>
      <div class="cell" style="border:none;border-top:1px solid var(--border)"><span class="lbl">Economic Life</span><span class="val">{{costApproach.economicLife}} years</span></div>
    </div>
  </div>
  {{/if}}
  <div class="row g2">
    <div class="cell"><span class="lbl">Depreciated Value of Improvements</span><span class="val">{{costApproach.depreciatedCostOfImprovements}}</span></div>
    <div class="cell"><span class="lbl">"As Is" Value by Cost Approach</span><span class="val" style="font-size:10pt;font-weight:800;color:var(--navy)">{{costApproach.indicatedValueByCostApproach}}</span></div>
  </div>
  {{/if}}

  {{#if hasIncomeApproach}}
