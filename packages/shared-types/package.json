{
  "name": "@l1/shared-types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for L1 Valuation Platform (canonical schema, report config, UAD 3.6)",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./property-record": {
      "types": "./dist/property-record.types.d.ts",
      "default": "./dist/property-record.types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "files": [
    "src",
    "dist"
  ]
}
